<a class="blog-back" href="/tools/">← Back to Tools</a>

<div class="blog-hero">
  <span class="eyebrow">Free Tool</span>
  <h1>SIP Calculator</h1>
  <p style="color:var(--ink); font-size:15.5px; margin-top:14px; max-width:560px;">
    Estimate the future value of your monthly SIP investment based on expected annual returns.
  </p>
</div>

<div class="calc-wrap">
  <div class="calc-form">
    <div class="calc-field">
      <label for="monthlyAmt">Monthly Investment (₹)</label>
      <input type="number" id="monthlyAmt" value="10000" min="0" step="500">
    </div>
    <div class="calc-field">
      <label for="sipRate">Expected Annual Return (%)</label>
      <input type="number" id="sipRate" value="12" min="0" step="0.1">
    </div>
    <div class="calc-field">
      <label for="sipTenure">Investment Duration</label>
      <div class="calc-tenure-row">
        <input type="number" id="sipTenure" value="10" min="1" step="1">
        <select id="sipTenureUnit">
          <option value="years" selected>Years</option>
          <option value="months">Months</option>
        </select>
      </div>
    </div>
  </div>

  <div class="calc-result">
    <div class="calc-result-main">
      <span class="calc-result-label">Maturity Value</span>
      <span class="calc-result-value" id="sipMaturity">₹0</span>
    </div>
    <div class="calc-result-row">
      <span>Total Amount Invested</span>
      <span id="sipInvested">₹0</span>
    </div>
    <div class="calc-result-row">
      <span>Estimated Returns</span>
      <span id="sipReturns">₹0</span>
    </div>
    <div class="calc-result-row calc-result-total">
      <span>Total Value (Invested + Returns)</span>
      <span id="sipTotal">₹0</span>
    </div>
  </div>
</div>

<p class="calc-note">This is an indicative estimate assuming a fixed monthly investment and a constant expected annual return, compounded monthly. Actual mutual fund returns fluctuate with market performance and are never guaranteed.</p>

<script>
  function formatINR(num) {
    return '₹' + Math.round(num).toLocaleString('en-IN');
  }

  function calculateSIP() {
    const P = parseFloat(document.getElementById('monthlyAmt').value) || 0;
    const annualRate = parseFloat(document.getElementById('sipRate').value) || 0;
    let tenure = parseFloat(document.getElementById('sipTenure').value) || 0;
    const tenureUnit = document.getElementById('sipTenureUnit').value;

    const n = tenureUnit === 'years' ? tenure * 12 : tenure;
    const i = annualRate / 12 / 100;

    let maturity = 0;
    if (n > 0) {
      if (i === 0) {
        maturity = P * n;
      } else {
        maturity = P * ((Math.pow(1 + i, n) - 1) / i) * (1 + i);
      }
    }

    const invested = P * n;
    const returns = maturity - invested;

    document.getElementById('sipMaturity').textContent = formatINR(maturity);
    document.getElementById('sipInvested').textContent = formatINR(invested);
    document.getElementById('sipReturns').textContent = formatINR(returns > 0 ? returns : 0);
    document.getElementById('sipTotal').textContent = formatINR(maturity);
  }

  ['monthlyAmt', 'sipRate', 'sipTenure', 'sipTenureUnit'].forEach(function (id) {
    document.getElementById(id).addEventListener('input', calculateSIP);
    document.getElementById(id).addEventListener('change', calculateSIP);
  });

  calculateSIP();
</script>
