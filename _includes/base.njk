<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} | Gourav Maharshi</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/style.css">
</head>
<body>

<nav>
  <div class="wrap">
    <a class="brand" href="/">Gourav <span>Maharshi</span></a>
    <ul class="navlinks">
      <li><a href="/#about">About</a></li>
      <li><a href="/#programs">Programs</a></li>
      <li><a href="/#experience">Experience</a></li>
      <li><a href="/#media">Media</a></li>
      <li><a href="/blog/">Blog</a></li>
      <li><a href="/tools/">Tools</a></li>
    </ul>
    <a class="navcta" href="/#contact">Get in Touch</a>
  </div>
</nav>

<main class="wrap page-main">
{{ content | safe }}
</main>

<footer>
  <p>© 2026 Gourav Maharshi — Senior Finance Trainer &amp; Consultant</p>
</footer>

<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
</body>
</html>
