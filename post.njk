---
layout: base.njk
---
<a class="blog-back" href="/blog/">← Back to Blog</a>
<article class="blog-post">
  <span class="eyebrow tl-date">{{ date | readableDate }}</span>
  <h1>{{ title }}</h1>
  {% if image %}<img src="{{ image }}" alt="{{ title }}">{% endif %}
  <div class="blog-post-body">
    {{ content | safe }}
  </div>
</article>
